<Window x:Class="Angajati.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Angajati"
        Height="700" Width="1050"
        MinHeight="560" MinWidth="820"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Br_BgDeep}"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="5"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource Br_Border}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLEBAR -->
            <Border Grid.Row="0" Background="{StaticResource Br_BgSide}" CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Ellipse Width="9" Height="9" Fill="{StaticResource Br_Accent}" Margin="0,0,8,0" Opacity="0.9"/>
                        <TextBlock Text="Gestiune Angajati" Foreground="{StaticResource Br_TxtPri}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="  |  Evidenta angajatilor" Foreground="{StaticResource Br_TxtMut}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="─" Style="{StaticResource Btn_WinCtrl}" Click="BtnMinimize_Click"/>
                        <Button Content="□" Style="{StaticResource Btn_WinCtrl}" Click="BtnMaximize_Click"/>
                        <Button Content="✕" Style="{StaticResource Btn_WinClose}" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource Br_BgSide}"
                        BorderBrush="{StaticResource Br_Border}" BorderThickness="0,1,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="MENIU" Foreground="{StaticResource Br_TxtMut}"
                                   FontSize="9.5" FontWeight="SemiBold" Margin="22,18,0,8"/>

                        <StackPanel Grid.Row="1" Margin="0,2,0,0">
                            <Button x:Name="BtnNavAngajati" Style="{StaticResource Btn_NavActive}" Click="NavAngajati_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F464;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Angajati" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnNavDept" Style="{StaticResource Btn_Nav}" Click="NavDept_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3E2;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Departamente" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnNavFilter" Style="{StaticResource Btn_Nav}" Click="NavFilter_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F50D;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Filtrare SP" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2" Margin="12,0,12,14" Padding="12,10"
                                Background="{StaticResource Br_BgCard}"
                                CornerRadius="8" BorderBrush="{StaticResource Br_Border}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TxtDbStatus" Text="● Conectat" FontSize="11"
                                           Foreground="{StaticResource Br_Success}"/>
                                <TextBlock Text="companie @ localhost" FontSize="10"
                                           Foreground="{StaticResource Br_TxtMut}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- MAIN -->
                <Border Grid.Column="1" Background="{StaticResource Br_BgMain}"
                        BorderBrush="{StaticResource Br_Border}" BorderThickness="0,1,0,0">
                    <Grid>

                        <!-- PAGE: ANGAJATI -->
                        <Grid x:Name="PageAngajati" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="24,18,24,14">
                                <StackPanel>
                                    <TextBlock Text="Angajati" Foreground="{StaticResource Br_TxtPri}"
                                               FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Adaugare angajat si afisare din view vw_AngajatiDepartamente"
                                               Foreground="{StaticResource Br_TxtSec}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="16,0,16,12"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="18,16">
                                <WrapPanel>
                                    <StackPanel Width="170" Margin="0,0,12,10">
                                        <TextBlock Text="NUME" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtNume"/>
                                        <TextBlock x:Name="ErrNume" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="170" Margin="0,0,12,10">
                                        <TextBlock Text="PRENUME" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtPrenume"/>
                                        <TextBlock x:Name="ErrPrenume" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="180" Margin="0,0,12,10">
                                        <TextBlock Text="FUNCTIE" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtFunctie"/>
                                        <TextBlock x:Name="ErrFunctie" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Width="130" Margin="0,0,12,10">
                                        <TextBlock Text="SALARIU (RON)" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtSalariu"/>
                                        <TextBlock x:Name="ErrSalariu" Style="{StaticResource ErrLabel}" Text="Numar valid"/>
                                    </StackPanel>
                                    <StackPanel Width="200" Margin="0,0,12,10">
                                        <TextBlock Text="DEPARTAMENT" Style="{StaticResource FormLabel}"/>
                                        <ComboBox x:Name="CmbDepartament"/>
                                        <TextBlock x:Name="ErrDept" Style="{StaticResource ErrLabel}" Text="Selectati departamentul"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,18,0,0">
                                        <Button Content="Adauga" Style="{StaticResource Btn_Primary}"
                                                Margin="0,0,8,0" Width="110" Click="BtnAdaugaAngajat_Click"/>
                                        <Button Content="Sterge" Style="{StaticResource Btn_Danger}"
                                                Width="90" Click="BtnStergeAngajat_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="16,0,16,16"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <DataGrid x:Name="DgAngajati" SelectionChanged="DgAngajati_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"            Binding="{Binding AngajatID}"           Width="55"/>
                                        <DataGridTextColumn Header="Nume"          Binding="{Binding Nume}"                Width="*"/>
                                        <DataGridTextColumn Header="Prenume"       Binding="{Binding Prenume}"             Width="*"/>
                                        <DataGridTextColumn Header="Functie"       Binding="{Binding Functie}"             Width="*"/>
                                        <DataGridTextColumn Header="Salariu"       Binding="{Binding Salariu, StringFormat=\{0:N2\} RON}" Width="130"/>
                                        <DataGridTextColumn Header="Departament"   Binding="{Binding DenumireDepartament}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- PAGE: DEPARTAMENTE -->
                        <Grid x:Name="PageDept" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="24,18,24,14">
                                <StackPanel>
                                    <TextBlock Text="Departamente" Foreground="{StaticResource Br_TxtPri}"
                                               FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Gestionarea departamentelor companiei"
                                               Foreground="{StaticResource Br_TxtSec}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="16,0,16,12"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" Padding="18,16">
                                <WrapPanel>
                                    <StackPanel Width="300" Margin="0,0,12,10">
                                        <TextBlock Text="DENUMIRE DEPARTAMENT" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="TxtDenumireDept"/>
                                        <TextBlock x:Name="ErrDenumire" Style="{StaticResource ErrLabel}" Text="Camp obligatoriu"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,18,0,0">
                                        <Button Content="Adauga" Style="{StaticResource Btn_Primary}"
                                                Margin="0,0,8,0" Width="110" Click="BtnAdaugaDept_Click"/>
                                        <Button Content="Sterge" Style="{StaticResource Btn_Danger}"
                                                Width="90" Click="BtnStergeDept_Click"/>
                                    </StackPanel>
                                </WrapPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="16,0,16,16"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <DataGrid x:Name="DgDept" SelectionChanged="DgDept_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"                  Binding="{Binding DepartamentID}"       Width="80"/>
                                        <DataGridTextColumn Header="Denumire departament" Binding="{Binding DenumireDepartament}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- PAGE: FILTRARE SP -->
                        <Grid x:Name="PageFilter" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="24,18,24,14">
                                <StackPanel>
                                    <TextBlock Text="Filtrare dupa departament" Foreground="{StaticResource Br_TxtPri}"
                                               FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Apeleaza procedura stocata sp_AngajatiDupaDepartament"
                                               Foreground="{StaticResource Br_TxtSec}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Margin="16,0,16,12" Padding="18,14"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Departament:" Foreground="{StaticResource Br_TxtSec}"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                    <ComboBox x:Name="CmbFilterDept" Width="260"
                                              SelectionChanged="CmbFilterDept_Changed"/>
                                    <TextBlock Text="— selecteaza un departament pentru a filtra —"
                                               Foreground="{StaticResource Br_TxtMut}"
                                               FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="16,0,16,16"
                                    Background="{StaticResource Br_BgCard}"
                                    BorderBrush="{StaticResource Br_Border}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <DataGrid x:Name="DgFilter">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID"          Binding="{Binding AngajatID}"           Width="55"/>
                                        <DataGridTextColumn Header="Nume"        Binding="{Binding Nume}"                Width="*"/>
                                        <DataGridTextColumn Header="Prenume"     Binding="{Binding Prenume}"             Width="*"/>
                                        <DataGridTextColumn Header="Functie"     Binding="{Binding Functie}"             Width="*"/>
                                        <DataGridTextColumn Header="Salariu"     Binding="{Binding Salariu, StringFormat=\{0:N2\} RON}" Width="130"/>
                                        <DataGridTextColumn Header="Departament" Binding="{Binding DenumireDepartament}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
